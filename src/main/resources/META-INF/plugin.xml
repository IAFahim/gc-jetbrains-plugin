<idea-plugin>
    <id>com.github.iafahim.gccopy</id>
    <name>gc Copy</name>
    <vendor url="https://github.com/IAFahim/gc">IAFahim</vendor>

    <description><![CDATA[
        Adds <b>Copy with gc</b> to the Project view and editor context menus.
        Runs a configurable command (default <code>gc -e cs -z \\ \n\n</code>) in the
        selected folder via a login shell, so <code>~/.local/bin</code> is on PATH, and
        reports the result. Change the command in <b>Settings &gt; Tools &gt; gc Copy</b>.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <notificationGroup id="gc.notifications" displayType="BALLOON"/>
        <applicationConfigurable
            parentId="tools"
            id="com.github.iafahim.gccopy.settings"
            displayName="gc Copy"
            instance="com.github.iafahim.gccopy.GcSettingsConfigurable"/>
    </extensions>

    <actions>
        <action id="com.github.iafahim.gccopy.GcCopyAction"
                class="com.github.iafahim.gccopy.GcCopyAction"
                text="Copy with gc"
                description="Run the configured gc command in this folder and copy to the clipboard">
            <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
