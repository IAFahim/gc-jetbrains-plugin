<idea-plugin>
    <id>com.github.iafahim.gccopy</id>
    <name>gc Copy</name>
    <vendor url="https://github.com/IAFahim/gc">IAFahim</vendor>

    <description><![CDATA[
        Ultimate AI context copy tool. Runs <code>gc</code> in any folder to generate LLM-ready markdown.
        Configure the command in <b>Settings | Tools | gc Copy</b>.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <notificationGroup id="gc.notifications" displayType="BALLOON"/>
        <applicationService serviceImplementation="com.github.iafahim.gccopy.GcSettings"/>
        <applicationConfigurable 
            parentId="tools" 
            instance="com.github.iafahim.gccopy.GcSettingsConfigurable" 
            id="com.github.iafahim.gccopy.GcSettingsConfigurable" 
            displayName="gc Copy"/>
    </extensions>

    <actions>
        <action id="gc.copy.action"
                class="com.github.iafahim.gccopy.GcCopyAction"
                text="Copy with gc"
                description="Run gc in this folder and copy to the clipboard">
            
            <!-- In Rider, everything eventually flows through these groups -->
            <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
            
            <!-- Bulletproof fallback: Standard Copy/Paste group -->
            <add-to-group group-id="CutCopyPasteGroup" anchor="last"/>
            
            <!-- Main menu fallback -->
            <add-to-group group-id="ToolsMenu" anchor="last"/>
            
            <keyboard-shortcut keymap="$default" first-keystroke="shift alt C"/>
        </action>
    </actions>
</idea-plugin>
