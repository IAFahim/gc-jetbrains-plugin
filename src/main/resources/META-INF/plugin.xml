<idea-plugin>
    <id>com.github.iafahim.gccopy</id>
    <name>gc Copy</name>
    <vendor url="https://github.com/IAFahim/gc">IAFahim</vendor>

    <description><![CDATA[
        Adds a <b>Copy with gc</b> action to the Project view context menu and Editor context menu.
        Runs the <code>gc</code> CLI in the selected folder and copies the result to the clipboard.
        Configure the command in <b>Settings | Tools | gc Copy</b>.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <notificationGroup id="gc.notifications" displayType="BALLOON"/>
        <applicationService serviceImplementation="com.github.iafahim.gccopy.GcCopySettings"/>
        <applicationConfigurable parentId="tools" instance="com.github.iafahim.gccopy.GcCopyConfigurable" id="com.github.iafahim.gccopy.GcCopyConfigurable" displayName="gc Copy"/>
    </extensions>

    <actions>
        <action id="gc.copy"
                class="com.github.iafahim.gccopy.GcCopyAction"
                text="Copy with gc"
                description="Run gc in this folder and copy to the clipboard">
            <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
    </actions>

</idea-plugin>
